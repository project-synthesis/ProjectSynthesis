{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-pr-ruff.sh",
            "timeout": 60000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-pr-svelte.sh",
            "timeout": 120000
          }
        ]
      }
    ]
  }
}
