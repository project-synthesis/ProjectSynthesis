# ── Project Synthesis — Docker Environment ──
# Copy to .env.docker:  cp .env.docker.example .env.docker
# Then fill in required values below.

# ─── LLM Provider (optional — configurable via UI) ──────────────────
# Leave blank to configure via the in-app setup flow (Settings > LLM Provider).
# If set here, the env var takes precedence and the UI shows "read-only".
ANTHROPIC_API_KEY=

# ─── Secrets (auto-generated on first startup) ──────────────────────
# These are automatically generated and persisted to data/.app_secrets
# on first startup. You only need to set them manually if you want to
# use specific values or share secrets across multiple instances.
# SECRET_KEY=
# JWT_SECRET=
# JWT_REFRESH_SECRET=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GITHUB_TOKEN_ENCRYPTION_KEY=

# ─── GitHub OAuth (optional — configurable via UI) ──────────────────
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/synthesis.db

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Redis password is auto-generated on first startup (stored in data/.redis_password).
# Set explicitly here to override the auto-generated value.
# REDIS_PASSWORD=

# ─── Networking ──────────────────────────────────────────────────────
# Backend MCP server binds all interfaces inside the container.
MCP_HOST=0.0.0.0
MCP_PORT=8001

# Health probe uses the Docker service name to reach the MCP container.
MCP_PROBE_HOST=mcp

# nginx serves on port 80; frontend URL must match.
FRONTEND_URL=http://localhost
CORS_ORIGINS=http://localhost

# Trust the Docker bridge network for X-Forwarded-For.
TRUSTED_PROXIES=172.16.0.0/12

# ─── SvelteKit ───────────────────────────────────────────────────────
# adapter-node CSRF origin — must match the external URL.
ORIGIN=http://localhost

# ─── JWT Cookies ─────────────────────────────────────────────────────
# Set to True when running behind HTTPS.
JWT_COOKIE_SECURE=false
