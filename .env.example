# Project Synthesis Environment Variables
# Copy this to .env and fill in values

# LLM Provider (at least one required)
# Option A: Claude Code CLI with Max subscription (preferred, zero cost)
#   Install: npm install -g @anthropic-ai/claude-code
#   Auth: claude login
# Option B: Anthropic API key
ANTHROPIC_API_KEY=

# GitHub App — user authentication (OAuth flow)
# Create a GitHub App at https://github.com/settings/apps/new
# Set the callback URL to: http://localhost:8000/auth/github/callback
GITHUB_APP_CLIENT_ID=       # OAuth client_id of the GitHub App
GITHUB_APP_CLIENT_SECRET=   # OAuth client_secret of the GitHub App

# GitHub App — bot / installation (for agent write operations)
# Found in your GitHub App settings page
GITHUB_APP_ID=              # Numeric App ID
GITHUB_APP_PRIVATE_KEY=     # RSA private key PEM (single line, \n-escaped)
GITHUB_APP_INSTALLATION_ID= # Installation ID for the platform bot account

# Security
SECRET_KEY=synthesis-dev-secret-key-change-in-production
GITHUB_TOKEN_ENCRYPTION_KEY=   # Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# MCP Server
MCP_PORT=8001
MCP_HOST=127.0.0.1

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/synthesis.db

# Testing — NEVER set True in production (exposes unauthenticated JWT minting)
# TESTING=False
