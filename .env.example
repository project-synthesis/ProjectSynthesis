# Project Synthesis — Environment Variables
# Copy to .env and fill in values as needed.
# All variables are optional — the app auto-detects and generates where possible.

# --- LLM Provider ---
# Option A: Claude CLI with Max subscription (auto-detected, zero cost)
#   Install: npm install -g @anthropic-ai/claude-code && claude login
# Option B: Anthropic API key (set here or via Settings UI)
ANTHROPIC_API_KEY=

# --- GitHub OAuth (optional — for codebase-aware optimization) ---
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:8000/api/github/auth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Security ---
# Auto-generated and persisted to data/.app_secrets if not set.
# SECRET_KEY=

# --- Network ---
# TRUSTED_PROXIES=127.0.0.1
# FRONTEND_URL=http://localhost:5199

# --- Rate Limiting ---
# OPTIMIZE_RATE_LIMIT=10/minute
# REFINE_RATE_LIMIT=10/minute
# FEEDBACK_RATE_LIMIT=30/minute
# DEFAULT_RATE_LIMIT=60/minute

# --- Context Budget ---
# MAX_RAW_PROMPT_CHARS=200000
# MAX_GUIDANCE_CHARS=20000
# MAX_CODEBASE_CONTEXT_CHARS=100000
# MAX_ADAPTATION_CHARS=5000

# --- Explore ---
# EXPLORE_MAX_FILES=40
# EXPLORE_TOTAL_LINE_BUDGET=15000
# EXPLORE_RESULT_CACHE_TTL=3600

# --- Models (override if needed) ---
# MODEL_SONNET=claude-sonnet-4-6
# MODEL_OPUS=claude-opus-4-7
# MODEL_HAIKU=claude-haiku-4-5

# --- Traces ---
# TRACE_RETENTION_DAYS=30
